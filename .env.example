# Supabase Local Development (Giá trị mặc định sau khi chạy `supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Database Connection (Dùng cho Prisma hoặc Direct Connection)
DATABASE_URL=

# (Tùy chọn) Service Role Key - CHỈ dùng ở Backend/Server-side
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth Local (Supabase CLI sẽ đọc dòng này từ .env hoặc .env.local lúc start)
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=